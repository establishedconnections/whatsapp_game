HOST=127.0.0.1
PORT=8080

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=whatsapp:+14155238886
STUDENT_TO=whatsapp:+31612345678

# Optioneel: voor WhatsApp-templateberichten buiten de 24-uurs sessie.
# Templatevoorbeeld: "Grieks quizwoord: {{1}}. Antwoord binnen 5 minuten met de Nederlandse vertaling."
TWILIO_CONTENT_SID=

# Quizritme
QUIZ_ENABLED=true
QUIZ_DAYS=mon,tue,wed,thu,fri,sat,sun
QUIZ_WINDOW_START=07:30
QUIZ_WINDOW_END=20:30

# Bloktijden waarop geplande vragen niet gestuurd worden.
# Voorbeeld hieronder: geen geplande vragen tijdens schooltijd op maandag t/m vrijdag.
QUIZ_BLOCK_WINDOWS=mon-fri 08:15-15:15

QUIZ_MIN_GAP_MINUTES=45
QUIZ_MAX_GAP_MINUTES=180
ANSWER_TIMEOUT_MINUTES=5

# Weekbeloningen. Het percentage telt zodra er minstens dit aantal woorden is beantwoord.
WEEKLY_GOAL_MIN_ANSWERS=10
REWARD_60=ijsje
REWARD_75=bios-bezoek
REWARD_90=t-shirt

# Optioneel: eigen micro-beloningen / grappige teksten.
# Gebruik | tussen varianten.
GOOD_MICRO_REWARDS=Mini-beloning: Grieks brein unlocked.|Meme-modus: professor vibes intensify.|Level up. Woord verslagen.
MISS_MICRO_TEXTS=Geen drama, dit is precies hoe herhalen werkt.|Deze gaat op de revanche-lijst.|Bijna. Dit woord komt gewoon nog een keer langs.
